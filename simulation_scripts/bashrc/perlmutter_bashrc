mpirun() {
    if [[ $# -lt 1 ]]; then
        echo "This is a wrapper to srun on perlmutter. It translates mpirun arguments to srun arguments." 
        echo "For example, -np or --np or -n will be translated to -n for srun."
        echo "Usage: mpirun -np <N> <exe> [args ...]"
        return 1
    fi

    local args=("$@")
    local out=("srun")
    local i=0

    while (( i < ${#args[@]} )); do
        case "${args[i]}" in
            -np|--np|-n)
                ((i++))
                if (( i >= ${#args[@]} )); then
                    echo "Error: ${args[i-1]} requires a value"
                    return 1
                fi
                out+=("-n" "${args[i]}")
                ;;
            *)
                out+=("${args[i]}")
                ;;
        esac
        ((i++))
    done

    command srun "${out[@]:1}"
}

check_job_status() {
    if [[ -z "$1" ]]; then
        echo "Usage: check_job_status <jobid>"
        return 1
    fi
    local jobid=$1
    local state
    state=$(squeue -j "$jobid" -h -o "%T" 2>/dev/null)
    if [[ -n "$state" ]]; then
        echo "$state"
        return 0
    fi
    state=$(sacct -j "$jobid" --format=State --noheader --parsable2 2>/dev/null | head -1)
    if [[ -n "$state" ]]; then
        echo "$state"
        return 0
    fi
    echo "NOT_FOUND"
    return 1
}

gif2mp4() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: gif2mp4 <input.gif> [output.mp4]"
        return 1
    fi
    local input="$1"
    local output="$2"
    if [[ -z "$output" ]]; then
        output="${input%.*}.mp4"
    fi
    ffmpeg -i "$input" -r 30 -c:v libx264 -crf 18 -pix_fmt yuv420p "$output"
}

